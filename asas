local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1500 
local BillboardCache = {}
local cleanNameCache = {}

local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
    ["Mythic"] = Color3.fromRGB(255, 0, 0),
}

-- === FONCTION DE NETTOYAGE INTELLIGENTE (ANTI-LAG) ===
local function getCleanName(tool)
    local rawName = tool.Name
    if cleanNameCache[rawName] then return cleanNameCache[rawName] end

    -- 1. On essaie de voir si le jeu a stocké le vrai nom dans un attribut (souvent le cas dans Block Spin)
    local attrName = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName")
    if attrName and attrName ~= "" then
        cleanNameCache[rawName] = attrName
        return attrName
    end

    -- 2. Sinon, on nettoie le nom : on enlève les chiffres et les IDs à la fin
    -- Exemple: "Leopard_12345" devient "Leopard"
    local clean = rawName:gsub("%d+", ""):gsub("_", " "):gsub("[%p%c]", ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
    
    -- Si le nom est trop bizarre ou vide, on garde le nom original mais sans les chiffres
    if not clean or #clean < 2 then
        clean = rawName:gsub("%d+", "")
    end

    cleanNameCache[rawName] = clean
    return clean
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not espInventoryEnabled then 
        bb.Enabled = false
        return 
    end
    
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local items = {}
    -- On check le Backpack + le Character
    for _, t in ipairs(p.Backpack:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(items, t) end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(items, t) end
    end

    for _, tool in ipairs(items) do
        local name = getCleanName(tool)
        
        local lbl = Instance.new("TextLabel", container)
        lbl.Size = UDim2.new(0, 180, 0, 14)
        lbl.BackgroundTransparency = 1
        lbl.Text = name
        lbl.Font = Enum.Font.SourceSansBold
        lbl.TextSize = 12
        lbl.TextStrokeTransparency = 0.3
        
        -- Couleur par rareté
        local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName")
        lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
    end

    bb.Enabled = (#items > 0)
end

local function createESP(p)
    if p == LocalPlayer then return end
    
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "InvESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) 
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
    end
    
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

-- === BOUCLE DE MISE À JOUR OPTIMISÉE (0 LAG) ===
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(0.8) -- Mise à jour fluide sans tuer les FPS
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

