-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1500 
local BillboardCache = {}
local cleanNameCache = {}

local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
    ["Mythic"] = Color3.fromRGB(255, 0, 0),
}

-- === SYSTÈME DE DÉTECTION DE NOM (BLOCK SPIN) ===
local function getRealItemName(tool)
    if not tool then return nil end
    local rawName = tool.Name
    
    -- 1. Vérification du Cache pour éviter les lags
    if cleanNameCache[rawName] then return cleanNameCache[rawName] end

    -- 2. Recherche dans les Attributes (Méthode principale Block Spin)
    local attr = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName") or tool:GetAttribute("WeaponName")
    if attr and tostring(attr) ~= "" then
        cleanNameCache[rawName] = tostring(attr)
        return tostring(attr)
    end

    -- 3. Recherche d'une StringValue à l'intérieur du Tool
    local innerName = tool:FindFirstChild("ItemName") or tool:FindFirstChild("WeaponName")
    if innerName and innerName:IsA("StringValue") then
        cleanNameCache[rawName] = innerName.Value
        return innerName.Value
    end

    -- 4. Nettoyage Intelligent du Nom (si l'ID est collé au nom)
    -- On enlève les chiffres et les caractères spéciaux type "_" ou "-"
    local clean = rawName:gsub("%d+", ""):gsub("[%p%c]", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    
    -- Si après nettoyage le nom est trop court, on garde le nom brut sans les chiffres
    if not clean or #clean < 2 then
        clean = rawName:gsub("%d+", "")
    end

    -- Si c'est toujours vide, on affiche le nom original
    if clean == "" then clean = rawName end

    cleanNameCache[rawName] = clean
    return clean
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not espInventoryEnabled then 
        bb.Enabled = false
        return 
    end
    
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    -- Liste des objets (Backpack + Main)
    local items = {}
    local backpack = p:FindFirstChild("Backpack")
    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if t:IsA("Tool") then table.insert(items, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") then table.insert(items, t) end
    end

    -- Affichage
    for _, tool in ipairs(items) do
        local name = getRealItemName(tool)
        if name and name:lower() ~= "fists" then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 15)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 13
            lbl.TextStrokeTransparency = 0.2
            
            -- Couleur par rareté ou type
            local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName")
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.fromRGB(255, 255, 255)
        end
    end

    bb.Enabled = (#items > 0)
end

local function createESP(p)
    if p == LocalPlayer then return end
    
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "BlockSpin_Inv"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -4, 0) -- Sous les pieds
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
    end
    
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

-- === BOUCLE OPTIMISÉE (0 LAG) ===
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(1) -- Mise à jour chaque seconde pour économiser les FPS
    end
end)

-- Init
for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

