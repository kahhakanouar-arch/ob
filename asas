-- === SYSTÈME DE NETTOYAGE ANTI-ID ===
local function getCleanName(tool)
    if not tool or not tool.Name then return nil end
    local raw = tool.Name
    
    -- Si c'est déjà en cache, on gagne du temps (FPS)
    if nameCache[raw] then return nameCache[raw] end

    -- Détection spécifique pour Blockspin
    local finalName = raw
    
    -- 1. Supprime "Handle" et les chiffres (IDs techniques)
    local clean = raw:gsub("Handle", ""):gsub("%d+", ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
    
    -- 2. Si le nom est vide ou juste "Tool", on cherche un attribut ou le nom du modèle
    if clean == "" or clean == "Tool" then
        if tool:GetAttribute("ItemName") then
            finalName = tool:GetAttribute("ItemName")
        elseif tool:FindFirstChild("Bobber") then
            finalName = "Fishing Rod"
        else
            -- Si on ne trouve rien de propre, on ne l'affiche pas (évite le spam d'IDs)
            return nil 
        end
    else
        finalName = clean
    end

    -- Mise en cache pour les prochaines frames
    nameCache[raw] = finalName
    return finalName
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not bb.Parent then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    -- Calcul de distance optimisé
    local dist = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")) 
        and (LocalPlayer.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude or 0
        
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end

    -- Collecte des outils (optimisée)
    local tools = {}
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    if #tools == 0 then
        bb.Enabled = false
        return
    end

    -- Mise à jour visuelle uniquement si nécessaire
    container:ClearAllChildren()
    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    layout.Padding = UDim.new(0, 2)

    bb.Enabled = espInventoryEnabled
    
    for _, tool in ipairs(tools) do
        local name = getCleanName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 11
            lbl.TextColor3 = RARITY_COLORS[tool:GetAttribute("Rarity")] or Color3.new(1, 1, 1)
            lbl.TextStrokeTransparency = 0.5
        end
    end
end

local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "BlockspinESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.5, 0)
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
        
        -- Boucle de mise à jour dédiée pour ce joueur
        task.spawn(function()
            while char.Parent and bb.Parent do
                updateESP(p)
                task.wait(UPDATE_INTERVAL)
            end
        end)
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

