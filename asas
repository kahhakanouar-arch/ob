-- === VERSION OPTIMISÉE POUR RODS ET ARMES ===
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1500 
local UPDATE_INTERVAL = 1.0 -- Augmenté pour éviter les lags
local BillboardCache = {}
local cleanNameCache = {} -- Cache pour ne pas recalculer les noms

local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
}

-- === SYSTÈME DE NETTOYAGE DES NOMS (FIX POUR RODS ET IDS) ===
local function getRealItemName(tool)
    if not tool or not tool.Name then return nil end
    local rawName = tool.Name
    
    if cleanNameCache[rawName] then return cleanNameCache[rawName] end

    -- 1. On cherche d'abord dans les attributs (méthode la plus propre)
    local attr = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName")
    if attr and tostring(attr) ~= "" then
        cleanNameCache[rawName] = tostring(attr)
        return tostring(attr)
    end

    -- 2. Nettoyage Regex : Retire les chiffres et IDs (ex: "MP5_123" -> "MP5")
    local clean = rawName:gsub("%d+", ""):gsub("[%p%c]", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    
    -- Si c'est une canne à pêche (Rod), on s'assure que le mot "Rod" reste
    if rawName:lower():find("rod") and not clean:lower():find("rod") then
        clean = clean .. " Rod"
    end

    local finalName = (clean ~= "" and #clean > 1) and clean or rawName
    cleanNameCache[rawName] = finalName
    return finalName
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not espInventoryEnabled then 
        bb.Enabled = false
        return 
    end
    
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local tools = {}
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    for _, tool in ipairs(tools) do
        local name = getRealItemName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 12
            lbl.TextStrokeTransparency = 0.4
            
            -- Couleur par rareté avec vos codes exacts 
            local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName") or "Common"
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
        end
    end
    bb.Enabled = (#tools > 0)
end

-- === INITIALISATION ===
local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "InventoryESP_Fixed"
        bb.Size = UDim2.new(0, 200, 0, 150)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) 
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        BillboardCache[p] = bb
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(UPDATE_INTERVAL)
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)
