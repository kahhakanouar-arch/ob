-- FONCTION DE FIX POUR LES NOMS (BLOCKSPIN SPECIAL)
local function getRealName(t)
    if not t then return nil end
    if nameCache[t.Name] then return nameCache[t.Name] end
    
    -- 1. Chercher une StringValue à l'intérieur (souvent appelée "ItemName" ou "WeaponName")
    local internalName = t:FindFirstChildOfClass("StringValue") or t:FindFirstChild("Name")
    if internalName and internalName:IsA("StringValue") and internalName.Value ~= "" then
        nameCache[t.Name] = internalName.Value
        return internalName.Value
    end

    -- 2. Chercher dans les attributs (très fréquent sur Blockspin)
    local attr = t:GetAttribute("DisplayName") or t:GetAttribute("ItemName") or t:GetAttribute("Weapon")
    if attr and tostring(attr) ~= "" then
        nameCache[t.Name] = tostring(attr)
        return nameCache[t.Name]
    end

    -- 3. Si le nom est un pur chiffre (ID), on essaie de nettoyer les caractères spéciaux
    local clean = t.Name:gsub("[%d%p]+", ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
    if clean and clean ~= "" and clean ~= "Tool" then
        nameCache[t.Name] = clean
        return clean
    end

    -- 4. Si vraiment rien n'est trouvé, on garde le nom d'origine
    return t.Name
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local lChar = LocalPlayer.Character
    local dist = (lChar and lChar:FindFirstChild("HumanoidRootPart")) and (lChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude or 0
    
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local tools = {}
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    if char then
        for _, t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end

    bb.Enabled = espInventoryEnabled and (#tools > 0)
    
    for _, tool in ipairs(tools) do
        local name = getRealName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 12
            lbl.TextStrokeTransparency = 0.5
            
            local rarity = tool:GetAttribute("RarityName") or tool:GetAttribute("Rarity")
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
        end
    end
end

local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "Inventory Esp"
        bb.Size = UDim2.new(0, 200, 0, 150)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) 
        bb.AlwaysOnTop = true
        bb.MaxDistance = MAX_DISTANCE
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
        updateESP(p)
        
        char.ChildAdded:Connect(function(child) if child:IsA("Tool") then task.wait(0.3); updateESP(p) end end)
        char.ChildRemoved:Connect(function(child) if child:IsA("Tool") then task.wait(0.3); updateESP(p) end end)
        
        local backpack = p:WaitForChild("Backpack", 5)
        if backpack then
            backpack.ChildAdded:Connect(function() updateESP(p) end)
            backpack.ChildRemoved:Connect(function() updateESP(p) end)
        end
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

-- Boucle de rafraîchissement lente pour économiser les FPS
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(UPDATE_INTERVAL)
    end
end)

