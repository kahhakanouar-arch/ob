-- === OPTIMISATION : SCAN UNIQUE DES ITEMS ===
local itemDatabase = {}
local function buildDatabase()
    for _, folder in ipairs({ReplicatedStorage:FindFirstChild("Items"), ReplicatedStorage:FindFirstChild("Tools"), StarterPack}) do
        if folder then
            for _, item in ipairs(folder:GetDescendants()) do
                if item:IsA("Tool") then
                    itemDatabase[item.Name:lower()] = item.Name
                end
            end
        end
    end
end
buildDatabase()

local function getRealName(t)
    if not t or not t.Name then return nil end
    local rawName = t.Name
    if nameCache[rawName] then return nameCache[rawName] end
    
    -- Si c'est un ID (long chiffre), on essaie de trouver un nom humain
    if rawName:match("^%d+$") then
        if t:FindFirstChild("Bobber") or rawName:lower():find("rod") then
            nameCache[rawName] = "Fishing Rod"
            return "Fishing Rod"
        end
        return nil -- Bloque l'affichage si c'est juste un ID moche
    end

    local clean = rawName:gsub("Handle", ""):gsub("%d+", ""):gsub("%s+", ""):lower()
    if itemDatabase[clean] then
        nameCache[rawName] = itemDatabase[clean]
        return itemDatabase[clean]
    end

    nameCache[rawName] = rawName:gsub("Handle", "")
    return nameCache[rawName]
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not bb.Parent then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local root = char.HumanoidRootPart
    local lChar = LocalPlayer.Character
    if lChar and lChar:FindFirstChild("HumanoidRootPart") then
        local dist = (lChar.HumanoidRootPart.Position - root.Position).Magnitude
        if dist > MAX_DISTANCE then
            bb.Enabled = false
            return
        end
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    
    local tools = {}
    local backpack = p:FindFirstChild("Backpack")
    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    if #tools == 0 then
        bb.Enabled = false
        return
    end

    container:ClearAllChildren()
    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    bb.Enabled = espInventoryEnabled
    
    for _, tool in ipairs(tools) do
        local name = getRealName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 11
            lbl.TextColor3 = RARITY_COLORS[tool:GetAttribute("RarityName") or tool:GetAttribute("Rarity")] or Color3.new(1, 1, 1)
            lbl.TextStrokeTransparency = 0.5
        end
    end
end

local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "InventoryESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3, 0) 
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
        task.spawn(function()
            while char.Parent and bb.Parent do
                updateESP(p)
                task.wait(UPDATE_INTERVAL)
            end
        end)
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

