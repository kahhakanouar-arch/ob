-- === SYSTÈME DE DÉTECTION SANS IDS (BLOCKSPIN SPECIAL) ===
local function getCleanName(tool)
    if not tool then return nil end
    local raw = tool.Name
    
    if nameCache[raw] then return nameCache[raw] end

    -- Si le nom est un ID (chiffres uniquement)
    if raw:match("^%d+$") then
        -- On cherche des indices à l'intérieur de l'outil pour trouver son vrai nom
        local weaponType = nil
        
        -- Liste des mots clés à chercher dans les enfants du Tool
        local keywords = {"ak47", "rpg", "glock", "shotgun", "rifle", "m4", "bat", "knife", "rod", "fishing"}
        
        for _, obj in ipairs(tool:GetDescendants()) do
            local objName = obj.Name:lower()
            for _, key in ipairs(keywords) do
                if objName:find(key) then
                    weaponType = key:upper()
                    break
                end
            end
            if weaponType then break end
        end
        
        if weaponType then
            nameCache[raw] = weaponType
            return weaponType
        else
            -- Si on ne trouve rien du tout, on n'affiche PAS l'ID (on laisse vide)
            return nil 
        end
    end

    -- Nettoyage standard pour les noms non-numériques
    local clean = raw:gsub("Handle", ""):gsub("Tool", ""):gsub("Model", ""):gsub("%s+", "")
    if clean == "" then return nil end
    
    nameCache[raw] = clean
    return clean
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local tools = {}
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container or #tools == 0 then
        bb.Enabled = false
        return
    end

    container:ClearAllChildren()
    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    bb.Enabled = espInventoryEnabled
    
    local foundAny = false
    for _, tool in ipairs(tools) do
        local name = getCleanName(tool)
        if name then
            foundAny = true
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 150, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = " " .. name .. " "
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 12
            lbl.TextColor3 = RARITY_COLORS[tool:GetAttribute("Rarity")] or Color3.new(1, 1, 1)
            lbl.TextStrokeTransparency = 0.5
        end
    end
    
    if not foundAny then bb.Enabled = false end
end

local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "CleanESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.5, 0)
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
        task.spawn(function()
            while char.Parent and bb.Parent do
                updateESP(p)
                task.wait(UPDATE_INTERVAL)
            end
        end)
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

