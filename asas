local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION OPTIMISÉE ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1500 
local BillboardCache = {}
local nameCache = {} 

local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
    ["Mythic"] = Color3.fromRGB(255, 0, 0),
}

-- === SYSTÈME DE RÉCUPÉRATION DE NOM RÉEL (ANTI-ID) ===
local function getRealName(tool)
    if not tool then return nil end
    if nameCache[tool.Name] then return nameCache[tool.Name] end
    
    -- 1. Tentative via les attributs (Méthode la plus rapide)
    local displayName = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName")
    if displayName and tostring(displayName) ~= "" then
        nameCache[tool.Name] = tostring(displayName)
        return tostring(displayName)
    end

    -- 2. Recherche dans ReplicatedStorage (On scanne une seule fois pour trouver le nom original)
    -- On cherche un objet qui a la même apparence mais un nom propre
    for _, item in ipairs(ReplicatedStorage:GetDescendants()) do
        if item:IsA("Tool") and item.Name ~= tool.Name then
            -- Si c'est le même type d'arme (même Handle), c'est le vrai nom
            if item:FindFirstChild("Handle") and tool:FindFirstChild("Handle") then
                if item.Handle:IsA("MeshPart") and tool.Handle:IsA("MeshPart") and item.Handle.MeshId == tool.Handle.MeshId then
                    nameCache[tool.Name] = item.Name
                    return item.Name
                end
            end
        end
    end

    -- 3. Nettoyage de secours (si rien n'est trouvé)
    local clean = tool.Name:gsub("%d+", ""):gsub("[%p%c]", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    local final = (clean ~= "" and #clean > 2) and clean or tool.Name
    nameCache[tool.Name] = final
    return final
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not espInventoryEnabled then 
        if bb then bb.Enabled = false end
        return 
    end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local tools = {}
    local backpack = p:FindFirstChild("Backpack")
    if backpack then
        for _, t in ipairs(backpack:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    for _, tool in ipairs(tools) do
        local name = getRealName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 12
            lbl.TextStrokeTransparency = 0.4
            
            local rarity = tool:GetAttribute("Rarity") or "Common"
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
        end
    end
    bb.Enabled = (#tools > 0)
end

local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "InvESP_Final"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) 
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        BillboardCache[p] = bb
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

-- Boucle de mise à jour 1 FPS pour économiser les performances
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(1) 
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

