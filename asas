local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1501 
local BillboardCache = {}
local cleanNameCache = {} 

local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
    ["Mythic"] = Color3.fromRGB(255, 0, 0),
}

-- === DÉTECTEUR UNIVERSEL (ARMES, RODS, PLATES, ETC.) ===
local function getUniversalName(tool)
    if not tool or not tool.Name then return nil end
    
    -- Si on a déjà nettoyé ce nom, on le sort du cache
    if cleanNameCache[tool.Name] then return cleanNameCache[tool.Name] end

    -- 1. On vérifie les attributs (souvent les vrais noms sont là)
    local attrName = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName") or tool:GetAttribute("WeaponName")
    if attrName and tostring(attrName) ~= "" then
        cleanNameCache[tool.Name] = tostring(attrName)
        return tostring(attrName)
    end

    -- 2. NETTOYAGE AGRESSIF DES IDS
    -- On retire TOUS les chiffres et les symboles bizarres (_ , - , #)
    local clean = tool.Name:gsub("[%d%p%c%s]+", " "):match("^%s*(.-)%s*$")
    
    -- Si le nom devient vide (ex: l'item s'appelle "123"), on garde le nom original sans les chiffres
    if not clean or #clean < 1 then
        clean = tool.Name:gsub("%d+", "")
    end

    -- 3. Cas spéciaux (Si c'est un RPG ou MP5 caché dans l'ID)
    local upperName = tool.Name:upper()
    if upperName:find("RPG") then clean = "RPG"
    elseif upperName:find("MP") then clean = "MP5"
    elseif upperName:find("REMI") then clean = "Remington"
    elseif upperName:find("PLATE") then clean = "Plate"
    end

    cleanNameCache[tool.Name] = clean
    return clean
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not espInventoryEnabled then 
        if bb then bb.Enabled = false end
        return 
    end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    -- On scanne TOUT l'inventaire sans exception
    local allTools = {}
    
    -- Objets dans le Backpack
    if p:FindFirstChild("Backpack") then
        for _, t in ipairs(p.Backpack:GetChildren()) do
            if t:IsA("Tool") then table.insert(allTools, t) end
        end
    end
    -- Objet en main
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") then table.insert(allTools, t) end
    end

    for _, tool in ipairs(allTools) do
        local name = getUniversalName(tool)
        if name and name:lower() ~= "fists" then
            -- Détection de rareté pour la couleur
            local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName") or "Common"
            
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 200, 0, 16)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 13
            lbl.TextStrokeTransparency = 0.3
        end
    end
    
    bb.Enabled = (#allTools > 0)
end

-- === INITIALISATION ===
local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "UniversalInv"
        bb.Size = UDim2.new(0, 200, 0, 150)
        bb.StudsOffset = Vector3.new(0, -4, 0)
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        BillboardCache[p] = bb
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(1) -- Optimisation anti-lag
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)
