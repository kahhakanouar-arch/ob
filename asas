local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterPack = game:GetService("StarterPack")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 2000 
local UPDATE_INTERVAL = 1.0 
local BillboardCache = {}
local nameCache = {} 

-- Tes couleurs exactes (Assure-toi que les noms correspondent aux raretés du jeu)
local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
    ["Mythic"] = Color3.fromRGB(255, 0, 0),
}

-- === SYSTÈME DE DÉCODAGE DES ITEMS ===
local function getRealNameAndColor(tool)
    if not tool then return nil, Color3.new(1,1,1) end
    
    -- 1. Récupération du Nom (Nettoyage des IDs)
    local displayName = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName")
    local finalName = displayName or tool.Name:gsub("%d+", ""):gsub("[%p%c]", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    if not finalName or #finalName < 2 then finalName = tool.Name end

    -- 2. Détection Forcée de la Rareté (Correction pour le blanc)
    local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName")
    
    -- Si pas trouvé, on cherche un objet "Rarity" à l'intérieur du Tool
    if not rarity then
        local rObj = tool:FindFirstChild("Rarity") or tool:FindFirstChild("RarityName")
        if rObj and (rObj:IsA("StringValue") or rObj:IsA("TextLabel")) then
            rarity = rObj.Value or rObj.Text
        end
    end

    local color = RARITY_COLORS[tostring(rarity)] or Color3.new(1, 1, 1)
    return finalName, color
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not espInventoryEnabled then 
        if bb then bb.Enabled = false end
        return 
    end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local tools = {}
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
        end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(tools, t) end
    end

    for _, tool in ipairs(tools) do
        local name, itemColor = getRealNameAndColor(tool)
        if name then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 15)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 13
            lbl.TextStrokeTransparency = 0.2
            lbl.TextColor3 = itemColor -- Application de la couleur ici
        end
    end
    bb.Enabled = (#tools > 0)
end

-- === INITIALISATION ET CRÉATION ===
local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "FinalColorESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.8, 0) 
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        BillboardCache[p] = bb
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

-- Boucle stable
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(UPDATE_INTERVAL)
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)
