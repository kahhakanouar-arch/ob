local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- === CONFIGURATION ===
local espInventoryEnabled = true 
local MAX_DISTANCE = 1500 
local BillboardCache = {}
local nameCache = {} 

-- Tes couleurs exactes intégrées 
local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Epic"] = Color3.fromRGB(237, 44, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51),
}

-- === NETTOYAGE INTELLIGENT (ANTI-ID) ===
local function getCleanName(tool)
    if not tool or not tool.Name then return nil end
    if nameCache[tool.Name] then return nameCache[tool.Name] end
    
    -- On check d'abord si le jeu a un nom d'affichage propre [cite: 2]
    local disp = tool:GetAttribute("ItemName") or tool:GetAttribute("DisplayName")
    if disp and tostring(disp) ~= "" then
        nameCache[tool.Name] = tostring(disp)
        return tostring(disp)
    end

    -- Nettoyage Regex : on vire les chiffres et symboles [cite: 2]
    local clean = tool.Name:gsub("%d+", ""):gsub("[%p%c]", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    local final = (clean ~= "" and #clean > 1) and clean or tool.Name
    
    nameCache[tool.Name] = final
    return final
end

local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb or not espInventoryEnabled then 
        if bb then bb.Enabled = false end
        return 
    end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    -- Optimisation distance pour les FPS [cite: 7]
    local dist = (Camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > MAX_DISTANCE then
        bb.Enabled = false
        return
    end

    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren() -- [cite: 8]

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local items = {}
    -- On récupère les outils du sac et de la main [cite: 9]
    for _, t in ipairs(p:FindFirstChild("Backpack") and p.Backpack:GetChildren() or {}) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(items, t) end
    end
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower() ~= "fists" then table.insert(items, t) end
    end

    for _, tool in ipairs(items) do
        local name = getCleanName(tool)
        if name then
            local lbl = Instance.new("TextLabel", container) -- [cite: 10]
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 12
            lbl.TextStrokeTransparency = 0.3 -- 
            
            -- APPLICATION DES COULEURS 
            local rarity = tool:GetAttribute("Rarity") or tool:GetAttribute("RarityName") or "Common"
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
        end
    end
    bb.Enabled = (#items > 0)
end

-- === CRÉATION ET BOUTON ===
local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10) -- [cite: 12]
        if not root then return end
        if BillboardCache[p] then BillboardCache[p]:Destroy() end
        
        local bb = Instance.new("BillboardGui", root) -- [cite: 12]
        bb.Name = "ColorInvESP"
        bb.Size = UDim2.new(0, 200, 0, 100)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) -- [cite: 12]
        bb.AlwaysOnTop = true
        
        local cont = Instance.new("Frame", bb) -- [cite: 13]
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        BillboardCache[p] = bb
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

-- Boucle 1 FPS pour rester à 60 FPS de jeu
task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(1) 
    end
end)

for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

