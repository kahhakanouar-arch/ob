--// Configuration
local espInventoryEnabled = true 
local MAX_DISTANCE = 2000 
local UPDATE_INTERVAL = 1.5 
local BillboardCache = {}
local nameCache = {} 

-- Couleurs autorisées (Common, Uncommon, Rare, Legendary, Omega)
local RARITY_COLORS = {
    ["Common"] = Color3.fromRGB(255, 255, 255),
    ["Uncommon"] = Color3.fromRGB(99, 255, 52),
    ["Rare"] = Color3.fromRGB(51, 170, 255),
    ["Legendary"] = Color3.fromRGB(255, 150, 0),
    ["Omega"] = Color3.fromRGB(255, 20, 51)
}

--// Nettoyage des noms (Anti-ID)
local function getRealName(t)
    if not t or not t.Name then return nil end
    if t.Name:match("^%d+$") then return nil end -- Ignore les IDs (ex: "123456")
    
    if nameCache[t.Name] then return nameCache[t.Name] end
    
    local clean = t.Name:gsub("%d+", ""):gsub("%s+", " "):match("^%s*(.-)%s*$")
    local finalName = (clean ~= "" and clean ~= "Tool") and clean or t.Name
    
    nameCache[t.Name] = finalName
    return finalName
end

--// Mise à jour de l'ESP
local function updateESP(p)
    local bb = BillboardCache[p]
    if not bb then return end
    
    local char = p.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then 
        bb.Enabled = false
        return 
    end
    
    local container = bb:FindFirstChild("EspContainer")
    if not container then return end
    container:ClearAllChildren()

    local layout = Instance.new("UIListLayout", container)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom 
    layout.Padding = UDim.new(0, 2)

    local tools = {}
    local function collect(folder)
        if not folder then return end
        for _, t in ipairs(folder:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower() ~= "fists" then
                -- On vérifie le nom d'abord
                if getRealName(t) then
                    table.insert(tools, t)
                end
            end
        end
    end

    collect(p:FindFirstChild("Backpack"))
    collect(char)

    bb.Enabled = espInventoryEnabled and (#tools > 0)
    
    for _, tool in ipairs(tools) do
        local name = getRealName(tool)
        local rarity = tool:GetAttribute("RarityName") or tool:GetAttribute("Rarity") or "Common"
        
        -- On affiche si c'est une des raretés que tu as demandé
        if RARITY_COLORS[rarity] or rarity == "Common" then
            local lbl = Instance.new("TextLabel", container)
            lbl.Size = UDim2.new(0, 180, 0, 14)
            lbl.BackgroundTransparency = 1
            lbl.Text = name
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextSize = 11
            lbl.TextStrokeTransparency = 0.4
            lbl.TextColor3 = RARITY_COLORS[rarity] or Color3.new(1, 1, 1)
        end
    end
end

--// Création Billboard
local function createESP(p)
    if p == LocalPlayer then return end
    local function setup(char)
        local root = char:WaitForChild("HumanoidRootPart", 10)
        if not root then return end
        
        local bb = Instance.new("BillboardGui", root)
        bb.Name = "Anouar_Inventory_ESP"
        bb.Size = UDim2.new(0, 200, 0, 150)
        bb.StudsOffset = Vector3.new(0, -3.5, 0) 
        bb.AlwaysOnTop = true
        bb.MaxDistance = MAX_DISTANCE
        
        local cont = Instance.new("Frame", bb)
        cont.Name = "EspContainer"
        cont.Size = UDim2.new(1, 0, 1, 0)
        cont.BackgroundTransparency = 1
        
        BillboardCache[p] = bb
        updateESP(p)
    end
    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

--// Lancement
for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then updateESP(p) end
        end
        task.wait(UPDATE_INTERVAL)
    end
end)

